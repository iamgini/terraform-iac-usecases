# Nginx Load Balancer Configuration for AAP
# Auto-generated by Ansible

upstream aap_gateways {
    least_conn;
{% for host in groups['automationgateway'] %}
    server {{ hostvars[host]['ansible_host'] }}:{{ gateway_port }};
{% endfor %}
}

# HTTP server - redirect to HTTPS (will be active after SSL setup)
server {
    listen 80;
    server_name {{ aap_domain }};

    # Allow certbot for certificate validation
    location /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
    }

    # Temporary: proxy to AAP (before SSL is setup)
    location / {
        proxy_pass https://aap_gateways;
        proxy_ssl_verify off;

        # Required headers for AAP
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
