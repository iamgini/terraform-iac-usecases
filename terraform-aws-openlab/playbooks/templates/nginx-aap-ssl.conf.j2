# Nginx Load Balancer Configuration for AAP with SSL
# Auto-generated by Ansible

upstream aap_gateways {
    least_conn;
{% for host in groups['automationgateway'] %}
    server {{ hostvars[host]['ansible_host'] }}:{{ gateway_port }};
{% endfor %}
}

# HTTP server - redirect to HTTPS
server {
    listen 80;
    server_name {{ aap_domain }};

    # Allow certbot for certificate renewal
    location /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
    }

    # Redirect all other traffic to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name {{ aap_domain }};

    # SSL Certificate (Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/{{ aap_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ aap_domain }}/privkey.pem;

    # SSL Configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Proxy to AAP Gateways
    location / {
        proxy_pass https://aap_gateways;
        proxy_ssl_verify off;

        # Required headers for AAP
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;

        # WebSocket support (for AAP UI)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Buffer settings
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Access and error logs
    access_log /var/log/nginx/aap_access.log;
    error_log /var/log/nginx/aap_error.log;
}
